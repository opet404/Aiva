{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/multi-chat", "destination": "/api/multi-chat" },
    { "source": "/api/status", "destination": "/api/status" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
